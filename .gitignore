# Python
__pycache__/
*.py[cod]
*.egg-info/
.Python

# Virtual environments
.venv/
venv/
env/

# Build artifacts (the spec in build/ IS tracked; its work dir and output are not)
build/work/
build/_version_info.txt
dist/

# Editor / IDE / Claude Code local files
.claude/
.vscode/
.idea/

# OS cruft
Thumbs.db
desktop.ini
.DS_Store

# App data — config, the provisioned Abogen env, ffmpeg, and uv's cache (multi-GB,
# created at runtime inside the folder so the app is self-contained)
/data/
config.json

# Workspace media folders (created on first run inside the app folder by default)
/Input/
/Output/
/Visual Audiobooks/

# Scratch
_dbg.py
*.7z
